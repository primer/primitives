#!/bin/bash

# Pre-push hook: ensure package.json and package-lock.json stay in sync

set -e

# Get list of changed files in commits being pushed
remote=$1
url=$2

# Get commits to be pushed (compare to remote)
commits=$(git rev-list @{u}..HEAD 2>/dev/null || git rev-list origin/HEAD..HEAD 2>/dev/null || echo "")

if [ -z "$commits" ]; then
  exit 0
fi

# Check if any package.json files changed
if git diff --name-only $commits 2>/dev/null | grep -q "package\.json"; then
  # If package.json changed, ensure package-lock.json also changed
  if ! git diff --name-only $commits 2>/dev/null | grep -q "package-lock\.json"; then
    echo "❌ Pre-push hook blocked: package.json changed but package-lock.json was not updated"
    echo ""
    echo "Run: npm install"
    echo "Then: git add package-lock.json"
    echo ""
    exit 1
  fi
fi

exit 0
