/**
 * Default light mode
 * @description Also used as a base for all other light mode themes
 */
{
  base: {
    color: {
      black: {
        $value: {
          colorSpace: 'hsl',
          components: [0, 0, 0],
          hex: '#000000',
        },
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'base/color/light',
          },
        },
      },
      inset: {
