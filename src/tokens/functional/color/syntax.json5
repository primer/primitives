{
  color: {
    ansi: {
      $description: 'ANSI terminal color palette for command-line interfaces and terminal emulators. Maps standard ANSI color names to theme-appropriate values.',
      $extensions: {
        'org.primer.llm': {
          usage: ['terminal-output', 'cli-interface', 'console-text', 'shell-prompt'],
          rules: 'Use exclusively for terminal/CLI contexts. Do NOT use for general UI—use semantic colors (fgColor, bgColor) instead. These colors follow ANSI naming conventions (black, red, green, yellow, blue, magenta, cyan, white) with bright variants.',
        },
      },
      black: {
        $value: '{base.color.neutral.11}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.neutral.4}',
          },
        },
      },
      'black-bright': {
        $value: '{base.color.neutral.9}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.neutral.6}',
          },
        },
      },
      white: {
        $value: '{base.color.neutral.11}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.neutral.10}',
          },
        },
      },
      'white-bright': {
        $value: '{base.color.neutral.6}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.neutral.11}',
          },
        },
      },
      gray: {
        $value: '{base.color.neutral.7}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.neutral.6}',
          },
        },
      },
      red: {
        $value: '{base.color.red.7}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.red.8}',
            'dark-protanopia-deuteranopia': '{base.color.orange.8}',
            'dark-protanopia-deuteranopia-high-contrast': '{base.color.orange.8}',
            'light-protanopia-deuteranopia': '{base.color.orange.7}',
            'light-protanopia-deuteranopia-high-contrast': '{base.color.orange.7}',
          },
        },
      },
      'red-bright': {
        $value: '{base.color.red.8}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.red.9}',
            'dark-protanopia-deuteranopia': '{base.color.orange.9}',
            'dark-protanopia-deuteranopia-high-contrast': '{base.color.orange.9}',
            'light-protanopia-deuteranopia': '{base.color.orange.8}',
            'light-protanopia-deuteranopia-high-contrast': '{base.color.orange.8}',
          },
        },
      },
      green: {
        $value: '{base.color.green.8}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.green.8}',
            'dark-tritanopia': '{base.color.blue.6}',
            'dark-tritanopia-high-contrast': '{base.color.blue.6}',
            'light-tritanopia': '{base.color.blue.8}',
            'light-tritanopia-high-contrast': '{base.color.blue.8}',
            'dark-protanopia-deuteranopia': '{base.color.blue.6}',
            'dark-protanopia-deuteranopia-high-contrast': '{base.color.blue.6}',
            'light-protanopia-deuteranopia': '{base.color.blue.8}',
            'light-protanopia-deuteranopia-high-contrast': '{base.color.blue.8}',
          },
        },
      },
      'green-bright': {
        $value: '{base.color.green.7}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.green.9}',
            'dark-tritanopia': '{base.color.blue.7}',
            'dark-tritanopia-high-contrast': '{base.color.blue.7}',
            'light-tritanopia': '{base.color.blue.7}',
            'light-tritanopia-high-contrast': '{base.color.blue.7}',
            'dark-protanopia-deuteranopia': '{base.color.blue.7}',
            'dark-protanopia-deuteranopia-high-contrast': '{base.color.blue.7}',
            'light-protanopia-deuteranopia': '{base.color.blue.7}',
            'light-protanopia-deuteranopia-high-contrast': '{base.color.blue.7}',
          },
        },
      },
      yellow: {
        $value: '{base.color.yellow.10}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.yellow.8}',
          },
        },
      },
      'yellow-bright': {
        $value: '{base.color.yellow.9}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.yellow.9}',
          },
        },
      },
      blue: {
        $value: '{base.color.blue.7}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.blue.6}',
          },
        },
      },
      'blue-bright': {
        $value: '{base.color.blue.6}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.blue.7}',
          },
        },
      },
      magenta: {
        $value: '{base.color.purple.7}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.purple.8}',
          },
        },
      },
      'magenta-bright': {
        $value: '{base.color.purple.6}',
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '{base.color.purple.9}',
          },
        },
      },
      cyan: {
        $value: {
          colorSpace: 'hsl',
          components: [184, 65.8, 31],
          hex: '#1b7c83',
        },
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '#39c5cf',
          },
        },
      },
      'cyan-bright': {
        $value: {
          colorSpace: 'hsl',
          components: [191.9, 55.3, 42.9],
          hex: '#3192aa',
        },
        $type: 'color',
        $extensions: {
          'org.primer.figma': {
            collection: 'mode',
            group: 'syntax',
          },
          'org.primer.overrides': {
            dark: '#56d4dd',
          },
        },
      },
    },
    prettylights: {
      $description: 'Syntax highlighting colors for code display. Used by GitHub code rendering (prettylights theme).',
      $extensions: {
        'org.primer.llm': {
          usage: ['code-syntax-highlighting', 'code-block', 'inline-code', 'diff-view'],
          rules: 'Use exclusively for syntax highlighting in code display contexts. Do NOT use for general UI text or backgrounds. Each token maps to a specific syntax element (comment, keyword, string, etc.).',
        },
      },
      syntax: {
        comment: {
          $value: '{base.color.neutral.11}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.neutral.10}',
            },
          },
        },
        constant: {
          $value: '{base.color.blue.9}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.blue.10}',
            },
          },
        },
        'constant-other-reference-link': {
          $value: '{base.color.blue.10}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.blue.10}',
            },
          },
        },
        entity: {
          $value: '{base.color.purple.10}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.purple.10}',
            },
          },
        },
        storage: {
          modifier: {
            import: {
              $value: '{base.color.neutral.11}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.neutral.10}',
                },
              },
            },
          },
        },
        'entity-tag': {
          $value: '{base.color.blue.9}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.green.10}',
              'dark-tritanopia': '{base.color.blue.10}',
              'dark-tritanopia-high-contrast': '{base.color.blue.10}',
              'dark-protanopia-deuteranopia': '{base.color.blue.10}',
              'dark-protanopia-deuteranopia-high-contrast': '{base.color.blue.10}',
            },
          },
        },
        keyword: {
          $value: '{base.color.red.10}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.red.10}',
              'dark-protanopia-deuteranopia': '{base.color.orange.10}',
              'dark-protanopia-deuteranopia-high-contrast': '{base.color.orange.10}',
              'light-protanopia-deuteranopia': '{base.color.orange.10}',
              'light-protanopia-deuteranopia-high-contrast': '{base.color.orange.10}',
            },
          },
        },
        string: {
          $value: '{base.color.blue.10}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.blue.10}',
            },
          },
        },
        variable: {
          $value: '{base.color.orange.10}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.orange.9}',
              'dark-high-contrast': '{base.color.orange.11}',
              'dark-dimmed-high-contrast': '{base.color.orange.11}',
              'dark-protanopia-deuteranopia-high-contrast': '{base.color.orange.11}',
              'dark-tritanopia': '{base.color.red.10}',
              'dark-tritanopia-high-contrast': '{base.color.red.11}',
              'light-tritanopia': '{base.color.red.10}',
              'light-tritanopia-high-contrast': '{base.color.red.10}',
            },
          },
        },
        brackethighlighter: {
          unmatched: {
            $value: '{base.color.red.9}',
            $type: 'color',
            $extensions: {
              'org.primer.figma': {
                collection: 'mode',
                group: 'syntax',
              },
              'org.primer.overrides': {
                dark: '{base.color.red.7}',
                'dark-protanopia-deuteranopia': '{base.color.orange.7}',
                'dark-protanopia-deuteranopia-high-contrast': '{base.color.orange.7}',
                'light-protanopia-deuteranopia': '{base.color.orange.9}',
                'light-protanopia-deuteranopia-high-contrast': '{base.color.orange.9}',
              },
            },
          },
          angle: {
            $value: '{base.color.neutral.7}',
            $type: 'color',
            $extensions: {
              'org.primer.figma': {
                collection: 'mode',
                group: 'syntax',
              },
              'org.primer.overrides': {
                dark: '{base.color.neutral.7}',
              },
            },
          },
        },
        invalid: {
          illegal: {
            text: {
              $value: '{fgColor.danger}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
              },
            },
            bg: {
              $value: '{bgColor.danger.muted}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
              },
            },
          },
        },
        carriage: {
          return: {
            text: {
              $value: '{base.color.neutral.1}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.neutral.10}',
                },
              },
            },
            bg: {
              $value: '{base.color.red.7}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.red.5}',
                  'dark-protanopia-deuteranopia': '{base.color.orange.5}',
                  'dark-protanopia-deuteranopia-high-contrast': '{base.color.orange.5}',
                  'light-protanopia-deuteranopia': '{base.color.orange.7}',
                  'light-protanopia-deuteranopia-high-contrast': '{base.color.orange.7}',
                },
              },
            },
          },
        },
        'string-regexp': {
          $value: '{base.color.green.8}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'syntax',
            },
            'org.primer.overrides': {
              dark: '{base.color.green.10}',
              'dark-tritanopia': '{base.color.blue.8}',
              'dark-tritanopia-high-contrast': '{base.color.blue.8}',
              'light-tritanopia': '{base.color.blue.8}',
              'light-tritanopia-high-contrast': '{base.color.blue.8}',
              'dark-protanopia-deuteranopia': '{base.color.blue.8}',
              'dark-protanopia-deuteranopia-high-contrast': '{base.color.blue.8}',
              'light-protanopia-deuteranopia': '{base.color.blue.8}',
              'light-protanopia-deuteranopia-high-contrast': '{base.color.blue.8}',
            },
          },
        },
        markup: {
          list: {
            $value: '{base.color.yellow.11}',
            $type: 'color',
            $extensions: {
              'org.primer.figma': {
                collection: 'mode',
                group: 'syntax',
              },
              'org.primer.overrides': {
                dark: '{base.color.yellow.10}',
              },
            },
          },
          heading: {
            $value: '{base.color.blue.8}',
            $type: 'color',
            $extensions: {
              'org.primer.figma': {
                collection: 'mode',
                group: 'syntax',
              },
              'org.primer.overrides': {
                dark: '{base.color.blue.5}',
              },
            },
          },
          italic: {
            $value: '{base.color.neutral.11}',
            $type: 'color',
            $extensions: {
              'org.primer.figma': {
                collection: 'mode',
                group: 'syntax',
              },
              'org.primer.overrides': {
                dark: '{base.color.neutral.10}',
              },
            },
          },
          bold: {
            $value: '{base.color.neutral.11}',
            $type: 'color',
            $extensions: {
              'org.primer.figma': {
                collection: 'mode',
                group: 'syntax',
              },
              'org.primer.overrides': {
                dark: '{base.color.neutral.10}',
              },
            },
          },
          deleted: {
            text: {
              $value: '{base.color.red.9}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.red.11}',
                  'dark-protanopia-deuteranopia': '{base.color.orange.11}',
                  'dark-protanopia-deuteranopia-high-contrast': '{base.color.orange.11}',
                  'light-protanopia-deuteranopia': '{base.color.orange.9}',
                  'light-protanopia-deuteranopia-high-contrast': '{base.color.orange.9}',
                },
              },
            },
            bg: {
              $value: '{base.color.red.2}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.red.3}',
                  'dark-protanopia-deuteranopia': '{base.color.orange.3}',
                  'dark-protanopia-deuteranopia-high-contrast': '{base.color.orange.3}',
                  'light-protanopia-deuteranopia': '{base.color.orange.2}',
                  'light-protanopia-deuteranopia-high-contrast': '{base.color.orange.2}',
                },
              },
            },
          },
          inserted: {
            text: {
              $value: '{base.color.green.8}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.green.11}',
                  'dark-tritanopia': '{base.color.blue.8}',
                  'dark-tritanopia-high-contrast': '{base.color.blue.8}',
                  'light-tritanopia': '{base.color.blue.8}',
                  'light-tritanopia-high-contrast': '{base.color.blue.8}',
                  'dark-protanopia-deuteranopia': '{base.color.blue.8}',
                  'dark-protanopia-deuteranopia-high-contrast': '{base.color.blue.8}',
                  'light-protanopia-deuteranopia': '{base.color.blue.8}',
                  'light-protanopia-deuteranopia-high-contrast': '{base.color.blue.8}',
                },
              },
            },
            bg: {
              $value: '{base.color.green.2}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.green.3}',
                  'dark-tritanopia': '{base.color.blue.2}',
                  'dark-tritanopia-high-contrast': '{base.color.blue.2}',
                  'light-tritanopia': '{base.color.blue.2}',
                  'light-tritanopia-high-contrast': '{base.color.blue.2}',
                  'dark-protanopia-deuteranopia': '{base.color.blue.2}',
                  'dark-protanopia-deuteranopia-high-contrast': '{base.color.blue.2}',
                  'light-protanopia-deuteranopia': '{base.color.blue.2}',
                  'light-protanopia-deuteranopia-high-contrast': '{base.color.blue.2}',
                },
              },
            },
          },
          changed: {
            text: {
              $value: '{base.color.orange.8}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.orange.11}',
                  'dark-tritanopia': '{base.color.red.11}',
                  'dark-tritanopia-high-contrast': '{base.color.red.11}',
                  'light-tritanopia': '{base.color.red.8}',
                  'light-tritanopia-high-contrast': '{base.color.red.8}',
                },
              },
            },
            bg: {
              $value: '{base.color.orange.3}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.orange.3}',
                  'dark-tritanopia': '{base.color.red.3}',
                  'dark-tritanopia-high-contrast': '{base.color.red.3}',
                  'light-tritanopia': '{base.color.red.3}',
                  'light-tritanopia-high-contrast': '{base.color.red.3}',
                },
              },
            },
          },
          ignored: {
            text: {
              $value: '{base.color.neutral.4}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.neutral.10}',
                },
              },
            },
            bg: {
              $value: '{base.color.blue.8}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.blue.4}',
                },
              },
            },
          },
        },
        meta: {
          diff: {
            range: {
              $value: '{base.color.purple.7}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.purple.9}',
                },
              },
            },
          },
        },
        sublimelinter: {
          gutter: {
            mark: {
              $value: '{base.color.neutral.6}',
              $type: 'color',
              $extensions: {
                'org.primer.figma': {
                  collection: 'mode',
                  group: 'syntax',
                },
                'org.primer.overrides': {
                  dark: '{base.color.neutral.5}',
                },
              },
            },
          },
        },
      },
    },
  },
}
