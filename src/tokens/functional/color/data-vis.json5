{
  data: {
    $description: 'Colors for data visualization including charts, graphs, and diagrams. Use these colors to differentiate data series. Emphasis variants are for lines, bars, and borders. Muted variants are for area fills and backgrounds.',
    $extensions: {
      'org.primer.llm': {
        usage: ['chart-series', 'graph-line', 'bar-fill', 'pie-segment', 'area-chart', 'data-point'],
        rules: 'Use data colors for visualizations only. Do NOT use for semantic meaning (use bgColor.success/danger instead). When using multiple series, ensure sufficient contrast between adjacent colors. Pair emphasis with muted variants of the same color for cohesive styling.',
      },
    },
    blue: {
      color: {
        emphasis: {
          $value: '{base.color.blue.7}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'component',
              scopes: ['bgColor', 'borderColor'],
            },
            'org.primer.overrides': {
              dark: '{base.color.blue.5}',
              'dark-dimmed': '{base.color.blue.5}',
              'dark-tritanopia': '{base.color.blue.5}',
              'dark-protanopia-deuteranopia': '{base.color.blue.5}',
              'light-high-contrast': '{base.color.blue.8}',
              'light-tritanopia-high-contrast': '{base.color.blue.8}',
              'light-protanopia-deuteranopia-high-contrast': '{base.color.blue.8}',
              'dark-high-contrast': '{base.color.blue.1}',
              'dark-dimmed-high-contrast': '{base.color.blue.3}',
              'dark-tritanopia-high-contrast': '{base.color.blue.1}',
              'dark-protanopia-deuteranopia-high-contrast': '{base.color.blue.1}',
            },
          },
        },
        muted: {
          $value: '{base.color.blue.2}',
          $type: 'color',
          $extensions: {
            'org.primer.figma': {
              collection: 'mode',
              group: 'component',
              scopes: ['bgColor'],
            },
            'org.primer.overrides': {
              dark: '{base.color.blue.2}',
            },
          },
        },
      },
    },
